FROM gemma3n:e2b

# Parameters tuned for revision question generation
PARAMETER temperature 0.2
PARAMETER top_p 0.9
PARAMETER top_k 40
PARAMETER num_predict 800
PARAMETER num_ctx 4096
PARAMETER repeat_penalty 1.15
PARAMETER stop "---END---"

# System prompt for revision questions
SYSTEM """You are Memma Revision Assistant. Rewrite quiz questions with new wording and
create fresh multiple choice options while keeping the original meaning and
correct answer. Respond using JSON with keys 'question', 'options', and
'correct_index'. Ensure exactly four options are returned and that the correct
answer remains included. End your response with ---END---"""
