# ========================
# GROQ API CONFIGURATION
# ========================

# Get your API key from: https://console.groq.com
GROQ_API_KEY=gsk_your_api_key_here
GROQ_MODEL=mixtral-8x7b-32768
GROQ_ENDPOINT=https://api.groq.com/openai/v1/chat/completions

# ========================
# AI SERVICE CONFIGURATION
# ========================

# Maximum characters to process in one request (prevents token overflow)
# ~12,000 characters ≈ 3,000 tokens
AI_MAX_TEXT_LENGTH=12000

# Maximum tokens in AI response
AI_MAX_TOKENS=1000

# API timeout in seconds
AI_TIMEOUT=60

# Temperature affects response randomness
# 0.0 = deterministic, consistent answers
# 0.7 = balanced (recommended)
# 2.0 = very creative/random
AI_TEMPERATURE=0.7

# Number of previous messages to include for context in chat
# More context = better understanding but slower responses
AI_CONTEXT_MESSAGES=10

# ========================
# OPTIONAL: OCR SERVICE
# ========================

# If you want OCR support for image-based PDFs
# OCR_SERVICE_URL=http://127.0.0.1:8001/ocr
